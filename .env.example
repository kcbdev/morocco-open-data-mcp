# Morocco Open Data MCP Server - Environment Variables

# Bank Al-Maghrib (BAM) API Keys
# Register at: https://www.bkam.ma/en/Statistical-Data
BAM_KEY_CHANGES=your_bam_changes_api_key_here
BAM_KEY_OBLIGATIONS=your_bam_obligations_api_key_here
BAM_KEY_TBILLS=your_bam_tbills_api_key_here

# ACLED API Key (Armed Conflict Location & Event Data Project)
# Register at: https://acleddata.com/api/
ACLED_API_KEY=your_acled_api_key_here

# World Bank API Key (optional, some endpoints require authentication)
# Register at: https://datahelpdesk.worldbank.org/dataconnect/
WORLD_BANK_API_KEY=your_worldbank_api_key_here

# OpenWeatherMap API Key (for climate data)
# Register at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ANTHROPIC_API_KEY (for MCP client integration)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Configuration
MCP_PORT=3000
MCP_HOST=localhost
NODE_ENV=development

# Cache Configuration (in seconds)
CACHE_TTL_DEFAULT=3600
CACHE_TTL_SHORT=300
CACHE_TTL_LONG=86400

# Rate Limiting (requests per minute)
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_STRICT=10
